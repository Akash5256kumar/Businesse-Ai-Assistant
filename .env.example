DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/apna_business
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_SECRET_KEY=change-me-in-production
EXPOSE_TEST_OTP=true
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Firebase — required for SMS OTP verification (phone auth)
# Only FIREBASE_PROJECT_ID is needed for ID token verification.
# The remaining three are used by the push-notification service (FCM).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# Alternatively, supply the full service-account JSON as a single string:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
